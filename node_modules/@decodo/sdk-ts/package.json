{
  "name": "@decodo/sdk-ts",
  "version": "2.2.0",
  "description": "Official TypeScript SDK for the Decodo APIs",
  "type": "module",
  "main": "./build/cjs/index.cjs",
  "module": "./build/esm/index.js",
  "types": "./build/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/esm/index.d.ts",
        "default": "./build/esm/index.js"
      },
      "require": {
        "types": "./build/cjs/index.d.cts",
        "default": "./build/cjs/index.cjs"
      }
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "codegen": "tsx src/codegen/codegen.ts",
    "build": "pnpm run codegen && pnpm run build:esm && pnpm run build:cjs",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "rm -rf build/cjs && mkdir -p build/cjs && esbuild src/index.ts --bundle --platform=node --format=cjs --external:zod --outfile=build/cjs/index.cjs && dts-bundle-generator -o build/cjs/index.d.cts --project tsconfig.build.json build/esm/index.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm run build:esm && pnpm run build:cjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.7.0",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "zod": "^4"
  },
  "license": "MIT"
}
